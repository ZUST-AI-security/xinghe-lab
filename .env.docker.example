# ============================================================
# 星河智安 AI 安全攻击可视化平台 — 本地 Docker 环境变量模板
# 用途：本地 docker compose build / push / up
# 使用方法：cp .env.docker.example .env，然后按需修改
# ============================================================

# ── 数据库配置 ────────────────────────────────────────────────
POSTGRES_DB=xinghe_lab
POSTGRES_USER=xinghe
POSTGRES_PASSWORD=xinghe_local_dev

# ── 安全密钥（本地开发可使用简单值，生产环境必须替换）────────
SECRET_KEY=local-dev-secret-key-change-in-prod
JWT_SECRET_KEY=local-dev-jwt-key-change-in-prod

# ── 应用模式 ──────────────────────────────────────────────────
DEBUG=false

# ── 镜像标签 ──────────────────────────────────────────────────
# docker compose build / push 时使用的标签
# 推送到 Docker Hub 后，服务器 .env 中的 IMAGE_TAG 需与此一致
IMAGE_TAG=latest

# ── 端口映射 ──────────────────────────────────────────────────
WEB_PORT=8080
BACKEND_PORT=8000

# ── 前端构建参数 ──────────────────────────────────────────────
# 留空：前端通过 Nginx 代理 /api/，无需跨域（推荐）
# 填写完整 URL 仅在前后端不同域时使用，如：http://api.example.com
VITE_API_BASE_URL=
VITE_API_VERSION=v1
VITE_ENABLE_DEBUG=false

# ── CORS 配置 ─────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:8080"]

# ── Celery 配置 ───────────────────────────────────────────────
CELERY_CONCURRENCY=1
CELERY_LOG_LEVEL=info
