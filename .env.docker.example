# Copy this file to .env before running docker compose.

POSTGRES_DB=xinghe_lab
POSTGRES_USER=xinghe
POSTGRES_PASSWORD=change-this-database-password

DEBUG=false
SECRET_KEY=change-this-to-a-long-random-string
JWT_SECRET_KEY=change-this-to-another-long-random-string

WEB_PORT=8080
BACKEND_PORT=8000

# Keep empty for same-origin Nginx proxy in Docker: /api/v1
VITE_API_BASE_URL=
VITE_API_VERSION=v1
VITE_ENABLE_DEBUG=false

# Add the final public origin when you bind a real domain.
CORS_ORIGINS=["http://localhost:8080"]

CELERY_CONCURRENCY=1
CELERY_LOG_LEVEL=info

# Docker image tag used by docker compose build/push.
IMAGE_TAG=latest
