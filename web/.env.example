# 星河智安 (XingHe ZhiAn) - 前端环境配置示例

# API配置
REACT_APP_API_BASE_URL=http://localhost:8000
REACT_APP_API_VERSION=v1

# 应用配置
REACT_APP_NAME=星河智安 AI安全攻击可视化平台
REACT_APP_VERSION=1.0.0

# 功能开关
REACT_APP_ENABLE_DEBUG=true
REACT_APP_ENABLE_ANALYTICS=false

# 模型配置
REACT_APP_DEFAULT_MODEL=resnet100_imagenet
REACT_APP_MAX_IMAGE_SIZE_MB=10

# 可视化配置
REACT_APP_CHART_ANIMATION=true
REACT_APP_HEATMAP_COLORMAP=hot
