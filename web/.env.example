# 星河智安 (XingHe ZhiAn) - 前端环境配置示例

# API配置
VITE_API_BASE_URL=http://localhost:8000
VITE_API_VERSION=v1

# 应用配置
VITE_APP_NAME=星河智安 AI安全攻击可视化平台
VITE_APP_VERSION=1.0.0

# 功能开关
VITE_ENABLE_DEBUG=true
VITE_ENABLE_ANALYTICS=false

# 模型配置
VITE_DEFAULT_MODEL=resnet100_imagenet
VITE_MAX_IMAGE_SIZE_MB=10

# 可视化配置
VITE_CHART_ANIMATION=true
VITE_HEATMAP_COLORMAP=hot
