# 星河智安 (XingHe ZhiAn) - 环境配置示例

# 应用配置
APP_NAME="星河智安 AI安全攻击可视化平台"
APP_VERSION="1.0.0"
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# 数据库配置
DATABASE_URL=sqlite:///./xinghe_zhi_an.db

# JWT配置
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis配置
REDIS_URL=redis://localhost:6379/0

# Celery配置
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# 模型配置
MODEL_CACHE_DIR=./models
IMAGENET_CLASSES_PATH=./models/imagenet_classes.txt

# YOLOv8配置
YOLO_MODEL_SIZE=n  # n, s, m, l, x
YOLO_CONF_THRESHOLD=0.25
YOLO_IOU_THRESHOLD=0.7

# 文件上传配置
MAX_FILE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,bmp,tiff

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# 开发模式配置
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]
