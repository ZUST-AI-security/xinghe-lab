# ============================================================
# 星河智安 AI 安全攻击可视化平台 — 生产环境变量模板
# 使用方法：cp .env.prod.example .env，然后修改下方必填项
# ============================================================

# ── 数据库配置 ────────────────────────────────────────────────
POSTGRES_DB=xinghe_lab
POSTGRES_USER=xinghe
# ⚠️ 必填：修改为强密码
POSTGRES_PASSWORD=change-this-database-password

# ── 安全密钥 ──────────────────────────────────────────────────
# ⚠️ 必填：生成方法：openssl rand -hex 32
SECRET_KEY=change-this-to-a-long-random-string
# ⚠️ 必填：与 SECRET_KEY 不同的另一个随机字符串
JWT_SECRET_KEY=change-this-to-another-long-random-string

# ── 应用模式 ──────────────────────────────────────────────────
# 生产环境保持 false（false 时 /docs 不可访问，弱密钥会报错）
DEBUG=false

# ── 镜像版本 ──────────────────────────────────────────────────
# 与本地 docker compose push 时使用的 IMAGE_TAG 保持一致
IMAGE_TAG=latest

# ── 端口映射 ──────────────────────────────────────────────────
# 前端对外端口（浏览器访问 http://your-server-ip:WEB_PORT）
WEB_PORT=8080
# 后端对外端口（可选，若只通过 Nginx 代理可不暴露）
BACKEND_PORT=8000

# ── CORS 跨域配置 ─────────────────────────────────────────────
# 填写实际可访问的前端地址（JSON 数组格式）
# 示例（IP 访问）：["http://1.2.3.4:8080"]
# 示例（域名访问）：["https://xinghe.example.com"]
CORS_ORIGINS=["http://localhost:8080"]

# ── 文件上传 ──────────────────────────────────────────────────
ALLOWED_IMAGE_TYPES=["jpg","jpeg","png","bmp","tiff"]

# ── Celery 配置 ───────────────────────────────────────────────
# 低配服务器（2核4G）建议保持 1，高配可适当增加
CELERY_CONCURRENCY=1
CELERY_LOG_LEVEL=info

# Per-user submission limit and stale active-task auto release.
MAX_CONCURRENT_TASKS_PER_USER=10
ACTIVE_TASK_STALE_SECONDS=2200
